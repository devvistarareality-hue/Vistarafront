{
  "expo": {
    "name": "Vistararealty",
    "slug": "Vistararealty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050D1A"
    },
    "userInterfaceStyle": "light",
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app uses your location to verify you are at the office before signing in."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Vistararealty to use Face ID for authentication."
        }
      ],
      "expo-sharing"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vistararealty.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.vistararealty.app",
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCuEw97S0W0PfipI4YTyhNrcdfVlZAum8k"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c9ab5511-dab6-42a9-8a63-4b949383b050"
      }
    }
  }
}
